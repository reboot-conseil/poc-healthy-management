# Copy this file to .env and fill in the values — never commit .env

# AssemblyAI — https://www.assemblyai.com/dashboard
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Speech model priority list (comma-separated).
# universal-3-pro: highest accuracy, supports FR/EN/ES/PT/DE/IT
# universal-2:     99 languages, fastest — used as automatic fallback
ASSEMBLYAI_SPEECH_MODELS=universal-3-pro,universal-2

# PostgreSQL async connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/workathon

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# Directory where uploaded audio files are stored (relative to backend/)
UPLOAD_DIR=uploads
